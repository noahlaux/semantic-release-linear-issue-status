{
  "name": "semantic-release-linear-issue-status",
  "version": "1.1.0",
  "description": "semantic-release plugin: set Linear issue workflow status after a successful release, based on issue IDs in release commits",
  "license": "MIT",
  "author": "Noah Laux",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noahlaux/semantic-release-linear-issue-status.git"
  },
  "bugs": {
    "url": "https://github.com/noahlaux/semantic-release-linear-issue-status/issues"
  },
  "homepage": "https://github.com/noahlaux/semantic-release-linear-issue-status#readme",
  "main": "lib/index.js",
  "files": [
    "lib",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "npm run lint:prettier && node --test test/extract-issue-identifiers.test.cjs test/index.test.cjs test/linear-api.test.cjs",
    "test:coverage": "node --test --experimental-test-coverage --test-coverage-include=\"lib/**\" test/extract-issue-identifiers.test.cjs test/index.test.cjs test/linear-api.test.cjs",
    "lint:prettier": "prettier --check \"lib/**/*.js\" \"test/**/*.cjs\"",
    "lint:prettier:fix": "prettier --write \"lib/**/*.js\" \"test/**/*.cjs\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "semantic-release": ">=21.0.0"
  },
  "keywords": [
    "linear",
    "semantic-release",
    "semantic-release-plugin",
    "release",
    "automation"
  ],
  "dependencies": {
    "@linear/sdk": "^81.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "prettier": "^3.8.2",
    "semantic-release": "^25.0.3"
  }
}
